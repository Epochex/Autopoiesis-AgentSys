# OpenAI-compatible provider defaults. For the Pengcheng GPU tunnel, open:
# /data/Netops-causality-remediation/ops/pengcheng_gpu/open_core_tunnel.sh
AUTOPOIESIS_LLM_BASE_URL=http://127.0.0.1:28000/v1
AUTOPOIESIS_LLM_API_KEY=sk-local
AUTOPOIESIS_LLM_MODEL=glm-fast

AUTOPOIESIS_GPU_BASE_URL=http://127.0.0.1:28000/v1
AUTOPOIESIS_GPU_API_KEY=sk-local
AUTOPOIESIS_GPU_MODEL=glm-fast

# Optional runtime paths and feature gates.
# AUTOPOIESIS_REPO_ROOT=/data/Autopoiesis-AgentSys
# AUTOPOIESIS_FRONTEND_DIST=/data/Autopoiesis-AgentSys/frontend/dist
# AUTOPOIESIS_CORS_ORIGINS=http://127.0.0.1:5173
# AUTOPOIESIS_REAL_DATASET_MANIFEST=/data/Autopoiesis-AgentSys/domains/network_rca/fixtures/real/manifest.json
# AUTOPOIESIS_LIVE_SYSLOG_PATH=/data/fortigate-runtime/input/fortigate.log
# AUTOPOIESIS_ENABLE_LIVE_DEVICE_ADAPTER=0
# AUTOPOIESIS_ENABLE_R230_INGESTOR=0

# Previous SELFEVO_* names remain read-only fallbacks during migration.
# Optional durable memory source. Leave unset for the deterministic in-process mode.
AUTOPOIESIS_MEMORY_DSN=
# Optional online semantic-memory route. When enabled, startup builds an HNSW
# base from the durable memory snapshot and new versions enter an exact Flat delta.
# Requires: pip install -e '.[dense]'
AUTOPOIESIS_ENABLE_VECTOR_MEMORY=0
