# OpenAI-compatible provider defaults. For the Waseda GPU tunnel, open:
# /data/Netops-causality-remediation/ops/waseda_gpu/open_core_tunnel.sh
SELFEVO_MODEL_BASE_URL=http://127.0.0.1:28000/v1
SELFEVO_MODEL_API_KEY=
SELFEVO_MODEL_ID=glm-fast
SELFEVO_MODEL_PROVIDER=waseda-gpu
SELFEVO_MODEL_TIMEOUT_MS=120000

# Legacy HELIX_MODEL_* variables are still accepted as fallback by the provider adapter.
